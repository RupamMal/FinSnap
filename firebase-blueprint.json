{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Configuration and balance info for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "initialBalance": { "type": "number" },
        "monthlyLimit": { "type": "number" },
        "currency": { "type": "string" }
      },
      "required": ["userId", "initialBalance", "monthlyLimit", "currency"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A single financial transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "category": { "type": "string" },
        "merchant": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "category", "merchant", "date", "createdAt"]
    }
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "User settings and limits"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "All financial transactions"
    }
  }
}
